@startuml
title Core Gameplay Loop

start
:Enter gameplay;
repeat
:Observe game state;
:Choose action;
:Perform action;
:Receive feedback;
:Game state changes;

if (Goal reached?) then (yes)
  :Reward or completion;
  stop
else (no)
  if (Failure state?) then (yes)
    if (Retry?) then (yes)
      :Retry or reset;
      :Return to gameplay;
    else (no)
      :Exit gameplay;
      stop
    endif
  else (no)
    :Continue playing;
  endif
endif
repeat while (Continue gameplay?) is (yes)
:Exit gameplay;
stop

@enduml
